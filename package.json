{
  "name": "demo-wallet",
  "version": "1.0.0",
  "private": true,
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node --files src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "test": "jest --runInBand",
    "lint": "tsc --noEmit -p tsconfig.json",
    "knex": "node -r ts-node/register ./node_modules/knex/bin/cli.js --knexfile knexfile.ts",
    "migrate:latest": "npm run knex -- migrate:latest",
    "migrate:make": "npm run knex -- migrate:make"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "knex": "^3.2.9",
    "mysql2": "^3.20.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
